<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentIDCardApp.MainWindow"
        Title="University Welcome Portal"
        Width="540" Height="680"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.Styles>
    <!-- Professional Input Styling -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#0F172A"/>
      <Setter Property="BorderBrush" Value="#CBD5E1"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="12,10,5,10"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border">
      <Setter Property="BorderBrush" Value="#94A3B8"/>
      <Setter Property="Background" Value="#F8FAFC"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
      <Setter Property="BorderBrush" Value="#2563EB"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>

    <!-- Professional Primary Button -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0F172A"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="0,12"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1E293B"/>
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#334155"/>
    </Style>
  </Window.Styles>

  <!-- Main Container -->
  <Panel>
    <!-- Custom Draggable Title Bar Area (Empty, just for dragging) -->
    <Border Height="40" VerticalAlignment="Top" IsHitTestVisible="False" Background="Transparent"/>

    <!-- Content Wrapper -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="40,60,40,40" Spacing="0">
        
        <!-- Header -->
        <StackPanel Spacing="12" Margin="0,0,0,40">
          <Border Width="56" Height="56" CornerRadius="12" Background="#E0E7FF" HorizontalAlignment="Left" Margin="0,0,0,8">
            <TextBlock Text="🏛️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          
          <TextBlock Text="Student Registration" 
                     FontSize="28" 
                     FontWeight="Bold" 
                     Foreground="#0F172A" 
                     LetterSpacing="-0.5"/>
          <TextBlock Text="Please enter your academic details to receive your personalized welcome packet and semester instructions." 
                     FontSize="14" 
                     Foreground="#64748B" 
                     TextWrapping="Wrap"
                     LineHeight="22"/>
        </StackPanel>

        <!-- Form Card -->
        <Border Background="White" 
                CornerRadius="12" 
                BorderBrush="#E2E8F0" 
                BorderThickness="1"
                Padding="32"
                BoxShadow="0 4 6 -1 #08000000, 0 2 4 -2 #08000000">
          
          <StackPanel Spacing="20">
            
            <!-- Name Field -->
            <StackPanel Spacing="6">
              <TextBlock Text="Full Legal Name" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
              <TextBox x:Name="NameInput" PlaceholderText="e.g. Junaid Mirza"/>
            </StackPanel>

            <!-- Department Field -->
            <StackPanel Spacing="6">
              <TextBlock Text="Academic Department" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
              <TextBox x:Name="DepartmentInput" PlaceholderText="e.g. Computer Science"/>
            </StackPanel>

            <!-- Semester Field -->
            <StackPanel Spacing="6">
              <TextBlock Text="Current Semester" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
              <TextBox x:Name="SemesterInput" PlaceholderText="e.g. 6th Semester"/>
            </StackPanel>

            <Border Height="1" Background="#F1F5F9" Margin="0,8"/>

            <!-- Action Button -->
            <Button Classes="primary" Content="Generate Welcome Message" Click="OnGenerateClick"/>
            
          </StackPanel>
        </Border>

        <!-- Output / Notification Area -->
        <Border x:Name="MessageBorder" 
                Margin="0,24,0,0"
                Background="#ECFDF5" 
                BorderBrush="#A7F3D0" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="20"
                IsVisible="False">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock x:Name="MessageIcon" Text="✓" FontSize="16" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
              <TextBlock x:Name="MessageTitleText"
                         Text="Registration Confirmed" 
                         FontSize="14" 
                         FontWeight="SemiBold" 
                         Foreground="#065F46" 
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="MessageText" 
                       Text="Welcome message will appear here." 
                       FontSize="14" 
                       Foreground="#047857" 
                       TextWrapping="Wrap"
                       LineHeight="22"
                       Margin="24,0,0,0"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Panel>
</Window>
